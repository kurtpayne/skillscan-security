{
  "name": "skillscan-security",
  "displayName": "SkillScan Security",
  "description": "Static security analysis for MCP skills and AI agent tools — detects prompt injection, tool poisoning, and supply-chain attacks",
  "version": "0.3.1",
  "publisher": "skillscan",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kurtpayne/skillscan-security"
  },
  "bugs": {
    "url": "https://github.com/kurtpayne/skillscan-security/issues"
  },
  "homepage": "https://skillscan.sh",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "security",
    "mcp",
    "prompt-injection",
    "ai-safety",
    "linter",
    "claude",
    "skill"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:yaml",
    "workspaceContains:**/SKILL.md",
    "workspaceContains:**/CLAUDE.md",
    "workspaceContains:**/.mcp.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "skillscan.scanFile",
        "title": "SkillScan: Scan Current File"
      },
      {
        "command": "skillscan.scanWorkspace",
        "title": "SkillScan: Scan Workspace"
      },
      {
        "command": "skillscan.openResults",
        "title": "SkillScan: Show Last Results"
      }
    ],
    "configuration": {
      "title": "SkillScan",
      "properties": {
        "skillscan.executablePath": {
          "type": "string",
          "default": "skillscan",
          "description": "Path to the skillscan executable. Defaults to 'skillscan' on PATH."
        },
        "skillscan.failOn": {
          "type": "string",
          "enum": ["block", "warn", "info"],
          "default": "warn",
          "description": "Minimum severity level to show as an error (red squiggle). Lower severities show as warnings."
        },
        "skillscan.scanOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan skill files when saved."
        },
        "skillscan.extraArgs": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Additional arguments to pass to skillscan (e.g. [\"--ml-detect\"])."
        },
        "skillscan.rulesPath": {
          "type": "string",
          "default": "",
          "description": "Path to a custom rules YAML file. Leave empty to use the bundled default ruleset."
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "skillscan.scanFile",
          "when": "resourceExtname == .md || resourceExtname == .yaml || resourceExtname == .yml || resourceFilename == SKILL.md || resourceFilename == CLAUDE.md",
          "group": "1_modification"
        }
      ],
      "explorer/context": [
        {
          "command": "skillscan.scanWorkspace",
          "group": "2_workspace"
        }
      ]
    },
    "statusBar": []
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish",
    "publish:ovsx": "ovsx publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.24.0",
    "ovsx": "^0.9.0"
  }
}
